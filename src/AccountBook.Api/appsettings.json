{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Database": {
    "RunMigrationsOnStartup": false
  },
  "ConnectionStrings": {
    "DefaultConnection": "",
    "ReadOnlyConnection": "",
    "Redis": ""
  },
  "Jwt": {
    "Key": "",
    "Issuer": "AccountBook",
    "Audience": "AccountBook"
  },
  "WeChat": {
    "AppId": "",
    "AppSecret": "",
    "token": "",
    "EnableContentSecurity": true
  },
  "AliyunOSS": {
    "AccessKeyId": "",
    "AccessKeySecret": "",
    "Endpoint": "https://oss-cn-shanghai.aliyuncs.com",
    "BucketName": "",
    "Domain": ""
  },
  "VoiceRecognition": {
    "AppId": "",
    "ApiKey": "",
    "ApiSecret": "",
    "ApiUrl": "https://vop.baidu.com/server_api"
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowMinutes": 1
  },
  "Cache": {
    "StatisticsTtlMinutes": 10
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "shared": true,
          "flushToDiskInterval": "00:00:01"
        }
      }
    ]
  }
}
