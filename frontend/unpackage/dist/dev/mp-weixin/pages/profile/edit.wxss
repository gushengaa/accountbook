
.edit-profile-page.data-v-ead3e541 {
	min-height: 100vh;
	background-color: #f5f5f5;
}

/* 自定义导航栏 */
.custom-navbar.data-v-ead3e541 {
	background: linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%);
	position: -webkit-sticky;
	position: sticky;
	top: 0;
	z-index: 100;
}
.navbar-content.data-v-ead3e541 {
	display: flex;
	align-items: center;
	justify-content: space-between;
	height: 88rpx;
	padding: 0 32rpx;
}
.nav-left.data-v-ead3e541, .nav-right.data-v-ead3e541 {
	width: 120rpx;
	display: flex;
	justify-content: center;
}
.nav-icon.data-v-ead3e541 {
	font-size: 36rpx;
	color: #fff;
	font-weight: bold;
}
.nav-title.data-v-ead3e541 {
	font-size: 32rpx;
	color: #fff;
	font-weight: 600;
}


/* 编辑表单 */
.edit-form.data-v-ead3e541 {
	padding: 60rpx 40rpx;
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 40rpx;
}

/* 头像编辑 */
.avatar-section.data-v-ead3e541 {
	display: flex;
	flex-direction: column;
	align-items: center;
}
.avatar-edit-btn.data-v-ead3e541 {
	background: transparent;
	border: none;
	padding: 0;
	margin: 0;
}
.avatar-preview.data-v-ead3e541 {
	width: 160rpx;
	height: 160rpx;
	border-radius: 80rpx;
	border: 4rpx solid #f0f0f0;
}
.avatar-tip.data-v-ead3e541 {
	font-size: 26rpx;
	color: #666;
	margin-top: 20rpx;
}

/* 输入区域 */
.input-section.data-v-ead3e541 {
	width: 100%;
}
.simple-input.data-v-ead3e541 {
	width: 100%;
	height: 88rpx;
	border: none;
	border-bottom: 2rpx solid #e0e0e0;
	padding: 0 20rpx;
	font-size: 30rpx;
	color: #333;
	background: transparent;
}
.simple-input.data-v-ead3e541:focus {
	border-bottom-color: #4CAF50;
}

/* 昵称行布局 */
.nickname-row.data-v-ead3e541 {
	display: flex;
	align-items: center;
	gap: 16rpx;
}
.nickname-input.data-v-ead3e541 {
	flex: 1;
}
.get-wechat-nickname-btn.data-v-ead3e541 {
	background: rgba(102, 126, 234, 0.1);
	border: 2rpx solid rgba(102, 126, 234, 0.3);
	border-radius: 8rpx;
	color: #F5A623;
	font-size: 24rpx;
	padding: 12rpx 20rpx;
	white-space: nowrap;
	transition: all 0.3s ease;
}
.get-wechat-nickname-btn.data-v-ead3e541:active {
	background: rgba(102, 126, 234, 0.2);
	transform: scale(0.95);
}

/* 保存按钮区域 */
.save-section.data-v-ead3e541 {
	padding: 40rpx;
	display: flex;
	justify-content: center;
}
.save-btn.data-v-ead3e541 {
	width: 100%;
	height: 88rpx;
    background: linear-gradient(135deg, #F5A623 0%, #F7B84D 100%);
	color: #fff;
	font-size: 32rpx;
	font-weight: 600;
	border: none;
	border-radius: 44rpx;
	box-shadow: 0 8rpx 16rpx rgba(102, 126, 234, 0.3);
	transition: all 0.3s ease;
}
.save-btn.data-v-ead3e541:active {
	transform: scale(0.98);
	box-shadow: 0 4rpx 8rpx rgba(102, 126, 234, 0.4);
}
