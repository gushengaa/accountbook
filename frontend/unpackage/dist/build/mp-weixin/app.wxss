page{background-color:#f5f5f5;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,Oxygen,Ubuntu,Cantarell,Fira Sans,Droid Sans,Helvetica Neue,sans-serif}.container{padding:24rpx}.card{background:#fff;border-radius:16rpx;padding:24rpx;margin-bottom:24rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.05)}.btn-primary{background:linear-gradient(135deg,#f5a623,#f7b84d);color:#fff;border-radius:50rpx;padding:24rpx 48rpx;font-size:32rpx;border:none}.btn-secondary{background:#f5f5f5;color:#333;border-radius:50rpx;padding:24rpx 48rpx;font-size:32rpx;border:none}.input{background:#f5f5f5;border-radius:16rpx;padding:24rpx;font-size:28rpx;border:none}.text-primary{color:#f5a623}.text-secondary{color:#999}.text-success{color:#5cb85c}.text-error{color:#e85d4b}.flex{display:flex}.flex-column{display:flex;flex-direction:column}.flex-center{display:flex;align-items:center;justify-content:center}.flex-between{display:flex;align-items:center;justify-content:space-between}.mt-sm{margin-top:16rpx}.mt-base{margin-top:24rpx}.mt-lg{margin-top:32rpx}.mb-sm{margin-bottom:16rpx}.mb-base{margin-bottom:24rpx}.mb-lg{margin-bottom:32rpx}
page{--status-bar-height:25px;--top-window-height:0px;--window-top:0px;--window-bottom:0px;--window-left:0px;--window-right:0px;--window-magin:0px}[data-c-h="true"]{display: none !important;}