# 腾讯云部署：124.222.233.110，www.planor.cn
# API 与 PostgreSQL 均在本机 Docker 中运行
# 复制为 .env 后填写：cp .env.example .env

# PostgreSQL 容器密码（请改为强密码）
POSTGRES_PASSWORD=your_strong_postgres_password

# API 连接串（Host=postgres 为 Docker 内部服务名，Password 须与 POSTGRES_PASSWORD 一致）
DB_CONNECTION=Host=postgres;Port=5432;Database=AccountBook;Username=postgres;Password=your_strong_postgres_password;Timezone=UTC

# 只读副本连接串（可选；留空则读写均走 DB_CONNECTION）
DB_READ_CONNECTION=

# Redis 连接串（Docker 内部服务名 redis）
REDIS_CONNECTION=redis:6379

JWT_KEY=your-jwt-secret-key-at-least-32-characters

WECHAT_APP_ID=wxXXXXXXXX
WECHAT_APP_SECRET=your_app_secret
WECHAT_TOKEN=your_wechat_token
WECHAT_ENABLE_CONTENT_SECURITY=true

OSS_ACCESS_KEY_ID=your_access_key
OSS_ACCESS_KEY_SECRET=your_access_secret
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
OSS_BUCKET_NAME=your_bucket
OSS_DOMAIN=https://your-bucket.oss-cn-shanghai.aliyuncs.com

# 百度语音识别（可选）
VOICE_APP_ID=
VOICE_API_KEY=
VOICE_API_SECRET=
